    "db:studio": "pnpm --filter @recruitflow/api db:studio",
    "screenshots": "node scripts/capture-screenshots.mjs"
  },
  "devDependencies": {
    "playwright": "^1.51.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0"
}
